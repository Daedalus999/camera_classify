{
  "expo": {
    "name": "ClimbSnap",
    "slug": "climb-snap",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "climbsnap",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ClimbSnap needs access to your photo library to import climbing photos and videos."
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.inconnu.climbsnap",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClimbSnap needs access to your photos to import climbing media.",
          "cameraPermission": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a820f8d-7e49-4958-917e-12ae05622b12"
      }
    },
    "owner": "in_connu"
  }
}
